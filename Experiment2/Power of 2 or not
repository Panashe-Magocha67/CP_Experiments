#include <iostream>
using namespace std;
bool isPowerOfTwo(int n) {
    return (n > 0) && ((n & (n - 1)) == 0);
}
int main() {
    int num1 = 16;
    int num2 = 10; 

    if (isPowerOfTwo(num1)) {
        cout << num1 << " is a power of 2" << endl;
    } else {
        cout << num1 << " is not a power of 2" << endl;
    }
    if (isPowerOfTwo(num2)) {
       cout << num2 << " is a power of 2" << endl;
    } else {
        cout << num2 << " is not a power of 2" <<endl;
    }

    return 0;
}
