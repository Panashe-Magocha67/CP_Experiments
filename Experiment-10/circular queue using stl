#include <iostream>
#include <deque>
using namespace std;

class CircularQueue {
    deque<int> dq;
    int capacity;

public:
    CircularQueue(int c) {
        capacity = c;
    }

    bool isEmpty() { return dq.empty(); }
    bool isFull() { return dq.size() == capacity; }

    void enqueue(int x) {
        if (isFull()) {
            cout << "Queue is full!\n";
            return;
        }
        dq.push_back(x);
    }

    void dequeue() {
        if (isEmpty()) {
            cout << "Queue is empty!\n";
            return;
        }
        dq.pop_front();
    }

    int getFront() {
        if (isEmpty()) {
            cout << "Queue is empty!\n";
            return -1;
        }
        return dq.front();
    }

    int getRear() {
        if (isEmpty()) {
            cout << "Queue is empty!\n";
            return -1;
        }
        return dq.back();
    }

    void display() {
        cout << "Queue elements: ";
        for (int x : dq) cout << x << " ";
        cout << endl;
    }
};

int main() {
    CircularQueue q(3);

    q.enqueue(10);
    q.enqueue(20);
    q.enqueue(30);
    q.display();

    cout << "Front: " << q.getFront() << endl;
    cout << "Rear: " << q.getRear() << endl;

    q.dequeue();
    q.enqueue(40);  // reuses space like a circular queue
    q.display();

    return 0;
}
