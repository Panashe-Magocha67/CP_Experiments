#include <bits/stdc++.h>
using namespace std;

bool isAnagram(string s1, string{
    if (s1.length() != s2.length()) {
        return false;
    }
    sort(s1.begin(), s1.end());
    sort(s2.begin(), s2.end());
    return s1 == s2;
}

int main() {
    string s1 = "ABCC";
    string s2 = "CBAC";

    if (isAnagram(s1, s2)) {
        cout << "The two strings are anagrams of each other";
    } else {
        cout << "The two strings are NOT anagrams";
    }

    return 0;
}
