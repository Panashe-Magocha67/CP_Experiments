#include <iostream>
#include <sstream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {
    string s1 = "I love programming in C++";

    stringstream ss(s1);
    vector<string> words;
    string word;

    while (ss >> word) {
        words.push_back(word);
    }

    reverse(words.begin(), words.end());

    for (size_t i = 0; i < words.size(); i++) {
        cout << words[i];
        if (i != words.size() - 1) cout << " ";
    }
    cout << endl;

    return 0;
}
