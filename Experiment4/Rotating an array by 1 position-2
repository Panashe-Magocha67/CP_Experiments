#include <iostream>
#include <vector>
using namespace std;
                    
void rotateclockwise(vector<int>& arr, int k) {

    int n = arr.size();

    k = k % n;

    vector<int> res;

    for (int i = 0; i < n; i++) {
        if (i < k) {
         
            res.push_back(arr[n + i - k]);
        } 
        else{
            res.push_back(arr[i - k]);
        }
    }

    for (int i = 0; i < n; i++) {
        arr[i] = res[i];
    }
}

int main() {
    
    vector<int> arr = {1, 2, 3, 4, 5, 6};
    int k = 1;
    
    rotateclockwise(arr, k);
    for (auto it : arr) {
        cout << it << " ";
    }
    return 0;
}
