#include <iostream>
#include <vector>
using namespace std;

int main() {
    vector<int> v = {2, 5, 7, 1, 3, 8};
    int n = v.size();

    for (int i = 0; i < n - 1; i++) {
      
        for (int j = 0; j < n - i - 1; j++) {
            if (v[j] > v[j + 1]) {
               
                int temp = v[j];
                v[j] = v[j + 1];
                v[j + 1] = temp;
            }
        }
    }

    cout << "Sorted array: ";
    for (int i = 0; i < n; i++) {
        cout << v[i] << " ";
    }
    cout << endl;

    return 0;
}
