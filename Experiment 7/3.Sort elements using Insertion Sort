#include <iostream>
#include <vector>
using namespace std;

int main() {
    vector<int> v = {2, 5, 7, 1, 3, 8};
    int n = v.size();

    
    for (int i = 1; i < n; i++) {
        int key = v[i];      
        int j = i - 1;

        
        while (j >= 0 && v[j] > key) {
            v[j + 1] = v[j];
            j--;
        }
        
        v[j + 1] = key;
    }

   
    cout << "Sorted array: ";
    for (int i = 0; i < n; i++) {
        cout << v[i] << " ";
    }
    cout << endl;

    return 0;
}
