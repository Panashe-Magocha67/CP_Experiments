#include <iostream>
#include <vector>
#include <algorithm> 
using namespace std;
int kthSmallest(vector<int>& arr, int k)
{
   sort(arr.begin(), arr.end());

    return arr[k - 1];
}
int main() {
   vector<int> arr = {12, 3, 5, 7, 19};
    int k = 2;

    try {
        cout << "K-th smallest element is " << kthSmallest(arr, k) << endl;
    } catch (const out_of_range& e) {
        cerr << e.what() << endl;
    }

    return 0;
}
