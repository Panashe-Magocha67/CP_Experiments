#include <iostream>
#include <vector>
using namespace std;

int main() {
    int hashsize, n;
    cout << "Enter hash table size: ";
    cin >> hashsize;
    cout << "Enter number of elements: ";
    cin >> n;

    vector<int> arr(n);
    cout << "Enter elements: ";
    for (int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    vector<vector<int>> hashtable(hashsize);

    for (int i = 0; i < n; i++) {
        int index = arr[i] % hashsize;
        hashtable[index].push_back(arr[i]);
    }

    cout << "\nHash Table:\n";
    for (int i = 0; i < hashsize; i++) {
        cout << i << " -> ";
        for (int j = 0; j < hashtable[i].size(); j++) {
            cout << hashtable[i][j] << " ";
        }
        cout << endl;
    }

    return 0;
}
